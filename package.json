{
  "name": "@notip/crypto-sdk",
  "version": "0.0.1",
  "description": "Client-side decryption library for NoTIP telemetry payloads",
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest --project unit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "check:formatting": "prettier --check src",
    "check:typecheck": "tsc -p tsconfig.json --noEmit",
    "check:linting": "eslint src --ext .ts --max-warnings 0",
    "prepublishOnly": "npm run check:typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "@vitest/browser": "^4.0.0",
    "playwright": "^1.0.0",
    "eslint": "^10.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
