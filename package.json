{
    "name": "@notip/crypto-sdk",
    "version": "1.1.1",
    "publishConfig": {
        "access": "public"
    },
    "description": "Client-side decryption library for NoTIP telemetry payloads",
    "license": "AGPL-3.0-only",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "fetch-dtos": "node ./scripts/update-openapi.js",
        "build": "tsup",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test:watch-coverage": "vitest --coverage",
        "sonar": "npm run test:coverage && dotenv -- sonar-scanner",
        "format": "prettier --write .",
        "check:format": "prettier --check .",
        "check:typecheck": "tsc --noEmit",
        "check:eslint": "eslint",
        "check": "npm run check:format && npm run check:typecheck && npm run check:eslint",
        "prepublishOnly": "npm run check && npm run test && npm run build"
    },
    "devDependencies": {
        "@hey-api/openapi-ts": "^0.94.5",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@vitest/coverage-v8": "^4.0.0",
        "dotenv-cli": "^8.0.0",
        "eslint": "^10.0.0",
        "prettier": "^3.0.0",
        "semantic-release": "^25.0.3",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.0.0",
        "vitest": "^4.0.0",
        "vitest-sonar-reporter": "^3.0.0"
    },
    "dependencies": {
        "@microsoft/fetch-event-source": "^2.0.1",
        "zod": "^4.3.6"
    }
}
